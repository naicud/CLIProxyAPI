    // ─── Test rapido endpoint ─────────────────────────────────────────────────
    {
      "label": "🧪 Test: /v1/models (docker, porta 9999)",
      "type": "shell",
      "command": "curl -s http://localhost:9999/v1/models -H 'Authorization: Bearer dev-local-key' | head -c 2000",
