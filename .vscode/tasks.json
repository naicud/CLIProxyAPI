{
  "version": "2.0.0",
  "tasks": [
    // ─── Docker Compose ───────────────────────────────────────────────────────
    {
      "label": "🐳 Docker: Start (porta 9999)",
      "type": "shell",
      "command": "find . -name '._*' -delete && docker compose up -d --build --pull never",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "docker"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Stop",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "docker"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Rebuild & Start",
      "type": "shell",
      "command": "find . -name '._*' -delete && docker compose build --pull never && docker compose up -d --remove-orphans --pull never",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "docker"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Logs",
      "type": "shell",
      "command": "docker compose logs -f cli-proxy-api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Restart",
      "type": "shell",
      "command": "docker compose restart cli-proxy-api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "docker"
      },
      "problemMatcher": []
    },
    {
      "label": "🧰 Go: Init local workspace",
      "type": "shell",
      "command": "mkdir -p bin temp/go-build temp/go-mod temp/go-tmp",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    // ─── Go Build ─────────────────────────────────────────────────────────────
    {
      "label": "🔨 Go: Build",
      "type": "shell",
      "command": "go build -o bin/cli-proxy-api ./cmd/server/",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GOTOOLCHAIN": "go1.26.0",
          "GOBIN": "${workspaceFolder}/bin",
          "GOCACHE": "${workspaceFolder}/temp/go-build",
          "GOMODCACHE": "${workspaceFolder}/temp/go-mod",
          "GOTMPDIR": "${workspaceFolder}/temp/go-tmp"
        }
      },
      "dependsOn": ["🧰 Go: Init local workspace"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$go"]
    },
    // ─── Provider Login (dentro il container) ─────────────────────────────────
    {
      "label": "🔑 Login: Gemini",
      "type": "shell",
      "command": "docker compose exec cli-proxy-api ./CLIProxyAPI -login -no-browser",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "login"
      },
      "problemMatcher": []
